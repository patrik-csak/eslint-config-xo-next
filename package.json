{
	"name": "eslint-config-xo-next",
	"version": "0.0.0",
	"description": "ESLint shareable config for using XO in Next.js projects",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/patrik-csak/eslint-config-xo-next.git"
	},
	"license": "MIT",
	"author": "Patrik Csak <p@trikcsak.com> (https://patrikcsak.com)",
	"sideEffects": false,
	"type": "module",
	"exports": {
		".": {
			"default": "./index.js",
			"types": "./index.d.ts"
		}
	},
	"files": [
		"index.d.ts",
		"index.js"
	],
	"scripts": {
		"build": "tsc",
		"inspect": "eslint-config-inspector --config=index.js",
		"lint": "eslint",
		"prepack": "npm run build",
		"pretest": "npm run build",
		"test": "node --test",
		"test:coverage": "npm run test -- --experimental-test-coverage"
	},
	"dependencies": {
		"eslint-plugin-jsx-a11y": "^6.10.2",
		"globals": "^17.7.0",
		"ow": "^3.1.1"
	},
	"devDependencies": {
		"@eslint/compat": "^2.1.0",
		"@eslint/config-inspector": "^3.0.4",
		"@next/eslint-plugin-next": "^16.2.10",
		"@tsconfig/node22": "^22.0.5",
		"@tsconfig/strictest": "^2.0.8",
		"@types/eslint-plugin-jsx-a11y": "^6.10.1",
		"@types/node": "^24.13.2",
		"eslint": "^10.6.0",
		"eslint-config-xo": "^0.57.0",
		"eslint-config-xo-react": "^0.31.0",
		"eslint-plugin-package-json": "^1.5.0",
		"typescript": "^6.0.3"
	},
	"peerDependencies": {
		"@next/eslint-plugin-next": "^16.0.0",
		"eslint": "^10.0.0",
		"eslint-config-xo-react": "^0.30.0"
	},
	"peerDependenciesMeta": {
		"eslint-config-xo-react": {
			"optional": true
		}
	},
	"engines": {
		"node": "22 - 24"
	},
	"devEngines": {
		"runtime": {
			"name": "node",
			"version": "^24"
		},
		"packageManager": {
			"name": "npm",
			"version": "^11.16"
		}
	},
	"allowScripts": {
		"unrs-resolver": false
	}
}
